# =============================================================================
# 云海 yunhai · 本地后端开发环境变量
# =============================================================================
# 用法：复制为 backend/.env 或在项目根目录 export 同名变量
# 生产完整清单见仓库根目录 .env.example（docker-compose.prod.yml）
# =============================================================================

# --- 缓存 ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=1800

# --- 路径（本地默认相对项目根）---
SCENIC_SPOTS_DIR=data/scenic-spots
TERRAIN_SNAPSHOTS_DIR=data/terrain
STATIC_DIR=
# STATIC_DIR=../frontend/dist

# --- CORS（本地 Vite 默认端口）---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- 访问统计 ---
ANALYTICS_ENABLED=false
ANALYTICS_ADMIN_TOKEN=dev_analytics_token_change_me
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_DB_PATH=data/analytics/analytics.db

# --- 云海标注 / ML / 社区 ---
CLOUDSEA_ENABLED=true
CLOUDSEA_ADMIN_TOKEN=dev_cloudsea_token_change_me
CLOUDSEA_DB_PATH=data/cloudsea/cloudsea.db
CLOUDSEA_AUTO_SNAPSHOT=true
CLOUDSEA_ML_ENABLED=true
CLOUDSEA_MODEL_PATH=data/cloudsea/models/cloudsea_ml_v6.pkl
CLOUDSEA_CONTRIBUTE_ENABLED=true
CLOUDSEA_DAILY_LABEL_CAP=30
CLOUDSEA_MAX_LOCATIONS_PER_CONTRIBUTOR=10
CLOUDSEA_DEDUP_RADIUS_M=500
CLOUDSEA_CURATED_SPOTS_DIR=
CLOUDSEA_CURATE_MIN_LABELS=1
CLOUDSEA_TRAIN_MIN_APPROVED=30
CLOUDSEA_ML_MIN_LABELS_PER_SPOT=30
CLOUDSEA_MODEL_MIN_LOOCV=0.70
CLOUDSEA_WATCH_ENABLED=true
CLOUDSEA_WATCH_LABEL_DAYS=7
CLOUDSEA_WATCH_USER_QUIET_MINUTES=60
CLOUDSEA_COMMUNITY_AUTO_APPROVE=true
CLOUDSEA_AUTO_APPROVE_TRUSTED=false

# --- AI 出行解读 ---
LLM_ADVISORY_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ADVISORY_CACHE_TTL=86400
LLM_ADVISORY_TIMEOUT_SEC=45

# --- 分享页 / OG 图 ---
PUBLIC_BASE_URL=http://localhost:5173
SHARE_SNAPSHOT_TTL=259200
SHARE_DAILY_IP_LIMIT=50
SHARE_ASSETS_DIR=data/share-assets
SHARE_CACHE_DIR=data/share-cache
APIMART_ENABLED=false
APIMART_API_KEY=
SHARE_OG_USE_IMAGE2=true

# --- 地图 POI（可选；POI 已改前端直连高德，服务端一般留空）---
TIANDITU_KEY=
