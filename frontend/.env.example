# =============================================================================
# 云海 yunhai · 前端构建时环境变量（Vite）
# =============================================================================
# 用法：
#   1. 复制为 frontend/.env.local（该文件已在 .gitignore，不会提交）
#   2. 本地开发：npm run dev
#   3. 生产镜像：./scripts/build-amd64.sh 会读取 .env.local 并注入 Docker build-arg
#
# 高德控制台：https://console.amap.com/
#   - 创建「Web端(JS API)」应用，填入 Key + 安全密钥
#   - 生产域名需加入白名单（如 yunhai.timkj.com）
# =============================================================================

VITE_AMAP_KEY=your_amap_web_key_here
VITE_AMAP_SECURITY=your_amap_security_code_here

# 可选：高德 Web 服务 Key（仅本地脚本 geocode_spots_amap.py 使用，不进前端 bundle）
# AMAP_WEB_SERVICE_KEY=your_amap_web_service_key_here
