# 本地部署配置（复制为 deploy.local.env，勿提交 Git）
#
#   cp scripts/deploy.local.env.example scripts/deploy.local.env
#   # 编辑 deploy.local.env 填入真实值
#
# 也可临时 export，或设置 DEPLOY_ENV_FILE 指向其他路径。

YUNHAI_SSH_KEY=/path/to/your/private_key
YUNHAI_HOST=root@your.server.example

# 可选（有默认值）
# YUNHAI_REMOTE_DIR=/opt/yunhai/patch
# YUNHAI_CONTAINER=yunhai-yunhai-1
