# =============================================================================
# 云海 yunhai · 生产 / Docker Compose 环境变量示例
# =============================================================================
# 用法：
#   - 生产：写入服务器 /opt/yunhai/docker-compose.prod.yml 的 environment 段
#   - 勿将真实密钥提交 Git；仅维护本 example 与 compose 模板
# 构建前端镜像另需 frontend/.env.local（VITE_AMAP_*，见 frontend/.env.example）
# 本地后端开发另见 backend/.env.example
# =============================================================================

# --- 基础运行时 ---
TZ=Asia/Shanghai
UVICORN_WORKERS=2
REDIS_URL=redis://redis:6379/0

# --- 应用路径（容器内；与 Dockerfile 默认一致）---
SCENIC_SPOTS_DIR=/app/data/scenic-spots
TERRAIN_SNAPSHOTS_DIR=/app/data/terrain
STATIC_DIR=/app/static

# --- 访问统计（Analytics）---
ANALYTICS_ENABLED=true
ANALYTICS_ADMIN_TOKEN=your_analytics_admin_token_here
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_DB_PATH=/app/data/analytics/analytics.db

# --- 云海标注 / ML / 社区 ---
CLOUDSEA_ENABLED=true
CLOUDSEA_ADMIN_TOKEN=your_cloudsea_admin_token_here
CLOUDSEA_DB_PATH=/app/data/cloudsea/cloudsea.db
CLOUDSEA_ML_ENABLED=true
CLOUDSEA_MODEL_PATH=/app/data/cloudsea/models/cloudsea_ml_v6.pkl
CLOUDSEA_CONTRIBUTE_ENABLED=true
CLOUDSEA_DAILY_LABEL_CAP=30
CLOUDSEA_MAX_LOCATIONS_PER_CONTRIBUTOR=10
# 可选（config 支持，生产未设则用默认）：
# CLOUDSEA_CURATED_SPOTS_DIR=/app/data/cloudsea/curated-spots
# CLOUDSEA_ML_MIN_LABELS_PER_SPOT=30
# CLOUDSEA_COMMUNITY_AUTO_APPROVE=true
# CLOUDSEA_WATCH_ENABLED=true
# CLOUDSEA_WATCH_LABEL_DAYS=7
# CLOUDSEA_WATCH_USER_QUIET_MINUTES=60

# --- AI 出行解读（OpenAI 兼容 API，如 DeepSeek）---
LLM_ADVISORY_ENABLED=true
LLM_API_KEY=sk-your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ADVISORY_CACHE_TTL=86400
# LLM_ADVISORY_TIMEOUT_SEC=45

# --- 分享页 / OG 图 ---
PUBLIC_BASE_URL=https://yunhai.timkj.com
SHARE_SNAPSHOT_TTL=259200
SHARE_ASSETS_DIR=/app/data/share-assets
SHARE_CACHE_DIR=/app/data/share-cache
# compose 需挂载宿主机目录，例如：
#   /opt/yunhai/data/share-assets:/app/data/share-assets
#   /opt/yunhai/data/share-cache:/app/data/share-cache

# --- 可选：Apimart 生成分享 OG 图（生产当前未启用时可省略）---
# APIMART_ENABLED=false
# APIMART_API_KEY=
# SHARE_OG_USE_IMAGE2=true
# SHARE_DAILY_IP_LIMIT=50

# --- 可选：服务端天地图 POI（已改前端高德，一般不需要）---
# TIANDITU_KEY=
