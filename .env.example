# 复制为 .env 或写入服务器 compose（勿提交真实 Key）
LLM_ADVISORY_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# 同点位+日期+气象指纹缓存，默认 86400 秒（1 天）；刷新按钮传 refresh=true 绕过
LLM_ADVISORY_CACHE_TTL=86400

# 分享页 / OG 图（真实 Key 仅写服务器环境变量）
PUBLIC_BASE_URL=
SHARE_SNAPSHOT_TTL=604800
APIMART_ENABLED=false
APIMART_API_KEY=
SHARE_OG_USE_IMAGE2=true
